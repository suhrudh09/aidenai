# OpenRouter LLM config (https://openrouter.ai/keys)
OPENROUTER_API_KEY=sk-or-...
# Any OpenRouter model slug. Examples:
#   openai/gpt-4o-mini
#   meta-llama/llama-3.1-8b-instruct
#   anthropic/claude-3.5-haiku
OPENROUTER_MODEL=openai/gpt-4o-mini

# Optional — used by OpenRouter for app ranking/attribution.
OPENROUTER_REFERER=http://localhost:5173
OPENROUTER_TITLE=AI Safety Guardrail
